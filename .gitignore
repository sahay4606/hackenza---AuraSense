# ═══════════════════════════════════════════════════
# AuraSense — .gitignore
# ═══════════════════════════════════════════════════

# ── Runtime Artifacts (generated by the pipeline — too large for git) ──
extracted_features/
extracted_ecapa/
raw_audio/
test_audio_temp/

# ── Model Checkpoints ──
*.pth

# ── Backup Zips ──
*.zip

# ── Submission CSVs (optional comparison outputs — NOT the main submission) ──
# NOTE: submission.csv is NOT gitignored — it's a required deliverable
submission_v1_aura.csv
submission_copy_of_aura.csv

# ── Python Environment ──
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── Jupyter ──
.ipynb_checkpoints/

# ── macOS ──
.DS_Store
._*

# ── IDE ──
.vscode/
.idea/

# ── Misc ──
saved/
another final/
